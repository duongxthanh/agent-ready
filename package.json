{
  "name": "agent-ready",
  "version": "0.1.0",
  "description": "Scan, score, and fix your website's agent-readiness — then prove the fix worked.",
  "keywords": [
    "agent-readiness", "aeo", "geo", "llms-txt", "seo", "ai-crawler",
    "gptbot", "claudebot", "schema-org", "json-ld", "claude-code", "cli"
  ],
  "homepage": "https://github.com/duongxthanh/agent-ready#readme",
  "repository": { "type": "git", "url": "git+https://github.com/duongxthanh/agent-ready.git" },
  "bugs": { "url": "https://github.com/duongxthanh/agent-ready/issues" },
  "author": "Thanh Dương",
  "type": "module",
  "license": "MIT",
  "engines": { "node": ">=20" },
  "bin": { "agent-ready": "dist/cli.js" },
  "main": "dist/index.js",
  "files": ["dist", "skill", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": { "cheerio": "^1.0.0" },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.14.0"
  }
}
